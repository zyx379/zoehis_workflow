# ZoeDevOps MCP Server — copy to .env and fill secrets (do NOT commit .env)

# GitLab (get_code)
GITLAB_BASE_URL=http://gitlab.zoesoft.com.cn
GITLAB_TOKEN=
GITLAB_DEFAULT_BRANCH=master

# Active project: zzey | seyy | nasyy | zzsyy | ...
ZOE_PROJECT_CODE=seyy

ZOE_API_LOG_PATH=/log-manage-service/log/search

# Per-project: ZOE_<code>_API_BASE_URL, ZOE_<code>_REDIS_*, ZOE_DB_<code>_*
# See existing .env on your machine or linx/docs/workflow.md
